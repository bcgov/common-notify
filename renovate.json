{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate configuration for common-notify with batched updates and auto-merge",
  "extends": [
    "github>bcgov/renovate-config#2025.10.1"
  ],
  "schedule": [
    "before 4am on Monday"
  ],
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Batch all npm patch and minor updates together",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "npm non-breaking updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Batch all Docker patch and minor updates together",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "Docker non-breaking updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Batch all GitHub Actions minor updates together",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions non-breaking updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Batch all Helm chart minor and patch updates together",
      "matchManagers": ["helm-values", "helmv3"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Helm non-breaking updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group all major updates separately and don't auto-merge",
      "matchUpdateTypes": ["major"],
      "groupName": "major dependency updates",
      "automerge": false
    },
    {
      "description": "Separate security updates for visibility",
      "matchDatasources": ["npm", "docker"],
      "matchUpdateTypes": ["patch"],
      "vulnerabilityAlerts": {
        "enabled": true
      },
      "groupName": "security updates",
      "automerge": false
    }
  ],
  "helm-values": {
    "enabled": true,
    "fileMatch": ["charts/.+/values\\.ya?ml$"]
  },
  "helmv3": {
    "enabled": true,
    "fileMatch": ["charts/.+/Chart\\.ya?ml$"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": false
  }
}
