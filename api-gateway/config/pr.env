# PR-specific Gateway Configuration
# This is used for temporary PR deployments in the DEV namespace
# Each PR gets its own isolated gateway configuration

# Gateway ID (using published gw-fe8c5 gateway)
GATEWAY_ID=gw-fe8c5

# Gateway service name includes PR number for uniqueness
GATEWAY_SERVICE_NAME=${GATEWAY_ID}-notify-pr-${PR_NUMBER}

# Backend host uses the PR-specific release name
BACKEND_HOST=${RELEASE_NAME}-backend.f6bc3f-dev.svc.cluster.local

# Route prefix includes PR number to avoid conflicts
ROUTE_PREFIX=${GATEWAY_ID}-pr-${PR_NUMBER}-

# All PRs share the same DEV gateway hostname
GATEWAY_HOSTNAME=${GATEWAY_ID}-notify.dev.api.gov.bc.ca

# DEV Keycloak configuration
KEYCLOAK_ISSUER=https://dev.loginproxy.gov.bc.ca/auth/realms/apigw
ALLOWED_AUDIENCE=ap-${GATEWAY_ID}-default-dev-dev

# Environment: DEV (PR deployments use DEV namespace and configuration)
