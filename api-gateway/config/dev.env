# DEV Environment Gateway Configuration
# For PR-specific deployments, RELEASE_NAME will be set to common-notify-${PR_NUMBER}
# For dedicated DEV deployment, RELEASE_NAME will be common-notify-dev

GATEWAY_ID=gw-fe8c5
GATEWAY_SERVICE_NAME=${GATEWAY_ID}-notify-dev
BACKEND_HOST=${RELEASE_NAME}-backend.f6bc3f-dev.svc.cluster.local
ROUTE_PREFIX=${GATEWAY_ID}-dev-
GATEWAY_HOSTNAME=${GATEWAY_ID}-notify.dev.api.gov.bc.ca
KEYCLOAK_ISSUER=https://dev.loginproxy.gov.bc.ca/auth/realms/apigw
FRONTEND_KEYCLOAK_ISSUER=https://dev.loginproxy.gov.bc.ca/auth/realms/standard
ALLOWED_AUDIENCE=ap-${GATEWAY_ID}-default-dev-dev
