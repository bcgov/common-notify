{
  "author": "NRIDS",
  "license": "Apache-2.0",
  "main": "index.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "deploy": "npm ci --ignore-scripts --no-update-notifier && npm run build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "make-badges": "istanbul-badges-readme --logo=vitest --exitCode=1",
    "make-badges:ci": "npm run make-badges -- --ci",
    "test": "vitest --dir src",
    "test:unit": "vitest --dir src",
    "test:unit:cov": "vitest run --coverage",
    "test:integration": "vitest --dir test",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/common": "^11.0.6",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.6",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.6",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/testing": "^11.0.6",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.7.7",
    "bull": "^4.14.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.0.0",
    "express-prom-bundle": "^8.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.7",
    "jwks-rsa": "^4.0.1",
    "jose": "^6.2.2",
    "nest-winston": "^1.10.1",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.21",
    "uuid": "^9.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.59.1",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.10.12",
    "chokidar": "^4.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.3",
    "istanbul-badges-readme": "^1.9.0",
    "prettier": "^3.5.3",
    "supertest": "^7.0.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.46.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "hono@<4.11.7": "4.11.7",
    "reflect-metadata": "^0.2.2",
    "chevrotain": {
      "lodash": "4.17.23"
    }
  }
}
