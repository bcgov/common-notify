        {
          "name": "Create Template (API Key)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Welcome Email\",\n  \"description\": \"Welcome template for new users\",\n  \"subject\": \"Welcome to Notify!\",\n  \"body\": \"Hello {{firstName}}, welcome to our service!\",\n  \"tags\": [\"welcome\", \"onboarding\"]\n}"
            },
            "url": {
              "raw": "{{kong_url}}/api/v1/admin/templates",
              "host": ["{{kong_url}}"],
              "path": ["api", "v1", "admin", "templates"]
            },
            "description": "Create a new email template using API key authentication.\n\nThis is a typical admin operation that uses API key authentication."
          },
          "response": []
        },
        {
          "name": "New Request",
          "request": {
            "method": "GET",
            "header": []
          },
          "response": []
        }
      ]
    },
