            "url": {
              "raw": "https://jwt.io/api/debug",
              "protocol": "https",
              "host": ["jwt", "io"],
              "path": ["api", "debug"]
            },
            "description": "Use JWT.io to decode and verify your JWT token.\n\nPaste your JWT_TOKEN environment variable here to see:\n- Header\n- Payload (claims)\n- Signature verification status"
          },
          "response": []
        },
