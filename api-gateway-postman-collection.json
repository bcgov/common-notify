            "url": {
              "raw": "{{kong_url}}/api/health",
              "host": ["{{kong_url}}"],
              "path": ["api", "health"]
            },
            "description": "Test health endpoint with API key authentication.\n\nKong validates:\n1. API key exists and is active\n2. API key is associated with a valid consumer\n\nSimple and secure for service-to-service communication."
          },
          "response": []
        },
        {
          "name": "Get Tenants (API Key)",
