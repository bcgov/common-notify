# Listen only on high ports (3000, 3001, 3003).
{
	metrics
	auto_https off
	admin 0.0.0.0:3003
	order coraza_waf first
}
:3000 {
	log {
		output stdout
		format console
		level {$LOG_LEVEL}
	}

	# Enable Coraza WAF
	coraza_waf {
		directives `
		Include /etc/caddy/coraza.conf
		`
	}

	# Proxy requests to API Gateway (Kong)
	reverse_proxy /api* {$VITE_API_GATEWAY_NOTIFY_URL} {
		header_up Host {http.reverse_proxy.upstream.hostport}
		header_up X-Real-IP {remote_host}
	}

	# Serve dynamic runtime configuration - MUST come before file_server
	handle_path /static/config.js {
		header Content-Type text/javascript
		respond `window.VITE_KEYCLOAK_URL="{$VITE_KEYCLOAK_URL}";
window.VITE_KEYCLOAK_REALM="{$VITE_KEYCLOAK_REALM}";
window.VITE_KEYCLOAK_CLIENT_ID="{$VITE_KEYCLOAK_CLIENT_ID}";
window.VITE_API_GATEWAY_NOTIFY_URL="{$VITE_API_GATEWAY_NOTIFY_URL}";`
	}

	root * /srv
	encode zstd gzip
	file_server
	@spa_router {
		not path /api*
		not path /static/config.js
		file {
			try_files {path} /index.html
		}
	}
	rewrite @spa_router {http.matchers.file.relative}
	header {
		-Server
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1;mode=block"
		Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
		X-Content-Type-Options "nosniff"
		Strict-Transport-Security "max-age=31536000"
		Content-Security-Policy "default-src 'self' https://*.gov.bc.ca;;
			script-src 'self' 'unsafe-inline' https://*.gov.bc.ca ;
			style-src 'self' https://fonts.googleapis.com https://use.fontawesome.com 'unsafe-inline';
			font-src 'self' https://fonts.gstatic.com;
			img-src 'self' data: https://fonts.googleapis.com https://www.w3.org https://*.gov.bc.ca https://*.tile.openstreetmap.org;
			frame-ancestors 'self';
			form-action 'self';
			block-all-mixed-content;
			connect-src 'self' https://*.gov.bc.ca wss://*.gov.bc.ca;"
		Referrer-Policy "same-origin"
		Permissions-Policy "fullscreen=(self), camera=(), microphone=()"
		Cross-Origin-Resource-Policy "cross-origin"
		Cross-Origin-Opener-Policy "same-origin"
	}
}
:3001 {
	handle /health {
		respond "OK"
	}
}
