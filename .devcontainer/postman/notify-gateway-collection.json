              "name": "GC Notify - Send Email",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  },
                  {
                    "key": "Authorization",
                    "value": "ApiKey-v1 {{gc_notify_api_key}}",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email_address\": \"{{recipient_email}}\",\n  \"template_id\": \"{{gc_notify_template_id}}\",\n  \"personalisation\": {\n    \"name\": \"Test User\"\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{gateway_url}}/api/gcnotify/v2/notifications/email",
                  "host": ["{{gateway_url}}"],
                  "path": ["api", "gcnotify", "v2", "notifications", "email"]
                },
                "description": "Send an email notification via GC Notify passthrough.\n\n**Prerequisites:**\n1. Get a JWT/OAuth2 token (Authentication folder)\n2. Set `gc_notify_api_key` to your GC Notify API key\n3. Set `gc_notify_template_id` to a valid template ID in your GC Notify account\n4. Set `recipient_email` to the target email address"
              },
              "response": []
